# ONE21 — example env (copy to .env and adjust)
# Rulare pe DDNS: http://platonos.mooo.com:3737

PORT=3737
JOIN_BASE_URL=http://platonos.mooo.com:3737/one21
ALLOWED_ORIGINS=http://localhost:3737,http://platonos.mooo.com:3737

# Database
# Default is sqlite (existing behavior)
# DB_DRIVER=sqlite
#
# Postgres (recommended for Cult Workspaces)
# DB_DRIVER=postgres
# PG_URL=postgres://<user>@localhost:5432/one21
#
# Optional pool tuning
# PG_POOL_MAX=10
# PG_POOL_IDLE_TIMEOUT_MS=30000
# PG_POOL_CONN_TIMEOUT_MS=5000

# Opțional (production):
# JWT_SECRET=your-secret
# NODE_ENV=production
